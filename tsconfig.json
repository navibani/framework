{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true,
    "incremental": true,
    "tsBuildInfoFile": "./dump/tsc/.tsbuildinfo",
    "skipLibCheck": true,
    "outDir": "./dump/tsc",
    "rootDir": "./",
    "sourceMap": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@framework/*": ["lib/*"]
    },
    "plugins": [
      { "name": "aio-lsp-plugin" },
      { "name": "builder-lsp-plugin" }
    ]
  },
  "include": [
    "lib/**/*.ts",
    "src/**/*.ts",
  ],
  "exclude": ["node_modules", "dist", "dump"]
}